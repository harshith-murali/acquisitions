# ==============================================================================
# Development Environment Configuration
# ==============================================================================
# Copy this file to .env.development and fill in your values
# File: .env.development.example
# Commit this file to git, never commit .env.development
# ==============================================================================

# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database Configuration: Neon Local (Docker container)
# This uses the neon-local service from docker-compose.dev.yml
DATABASE_URL=postgres://neon:npg@neon-local:5432/neondb
NEON_LOCAL=true
NEON_LOCAL_FETCH_ENDPOINT=http://neon-local:5432/sql

# ==============================================================================
# Neon API Configuration (for Ephemeral Branches)
# Get these from: https://console.neon.tech → Account Settings → API keys
# ==============================================================================

# Your Neon API authentication token
# Example: neon_api_key_abc123xyz
NEON_API_KEY=replace_with_neon_api_key

# Your Neon Project ID
# Example: proj_abc123xyz
NEON_PROJECT_ID=replace_with_neon_project_id

# ==============================================================================
# Neon Branching Configuration (Optional)
# ==============================================================================

# Branch to fork from (empty = use project's default branch)
# You can set this to a specific branch ID to branch from another branch
PARENT_BRANCH_ID=

# Automatically delete the ephemeral branch when Neon Local stops
# Set to 'false' if you want to keep the branch for inspection
DELETE_BRANCH=true
